# ============================================================
# Database (Supabase / PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://user:password@host:5432/dbname
DIRECT_URL=postgresql://user:password@host:5432/dbname   # untuk prisma migrate jika pakai Supabase pooler

# ============================================================
# Auth
# ============================================================
JWT_SECRET=your-super-secret-key-minimal-32-characters
JWT_EXPIRES_IN=7d

# ============================================================
# Supabase Storage
# ============================================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Midtrans Payment Gateway
# ============================================================
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx    # prefix SB- untuk sandbox
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false    # ganti true saat deploy ke production

# ============================================================
# Business Rules (opsional, ada default value)
# ============================================================
PLATFORM_FEE_PERCENT=5        # persentase fee platform (default: 5%)
WITHDRAWAL_ADMIN_FEE=5000     # biaya admin withdrawal dalam Rupiah (default: 5000)

# ============================================================
# Server
# ============================================================
PORT=3001
NODE_ENV=development
